generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URI")
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  active
  inactive
}

model UserModel {
  id          String @id @default(uuid())

  firstName   String
  lastName    String
  middleName  String?

  birthDate   DateTime

  email       String @unique

  password    String

  role        UserRole
  status      UserStatus @default(active)

  token TokenModel?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TokenModel {
  id Int @id @default(autoincrement())

  refreshToken String @unique

  // One refresh token per user.
  // Can be extended later to support multiple devices/sessions.
  userId String @unique

  user UserModel @relation(fields: [userId], references: [id], onDelete: Cascade )
}