generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URI")
}

enum UserRole {
  admin
  user
}

enum UserStatus {
  active
  blocked
  pending
}

model UserModel {
  id          String @id @default(uuid())

  firstName   String
  lastName    String
  middleName  String?

  birthDate   DateTime

  email       String @unique

  password    String

  role        UserRole
  status      UserStatus

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}